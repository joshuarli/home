$ modinfo snd_hda_intel
filename:       /lib/modules/6.18.39-0-lts/kernel/sound/hda/controllers/snd-hda-intel.ko
description:    Intel HDA driver
license:        GPL
parm:           snoop:Enable/disable snooping
parm:           align_buffer_size:Force buffer and period sizes to be multiple of 128 bytes.
parm:           power_save_controller:Reset controller in power save mode.
parm:           pm_blacklist:Enable power-management denylist
parm:           power_save:Automatic power-saving timeout (in second, 0 = disable).
parm:           ctl_dev_id:Use control device identifier (based on codec address).
parm:           dmic_detect:Allow DSP driver selection (bypass this driver) (0=off, 1=on) (default=1); deprecated, use snd-intel-dspcfg.dsp_driver option instead
parm:           beep_mode:Select HDA Beep registration mode (0=off, 1=on) (default=1).
parm:           enable_msi:Enable Message Signaled Interrupt (MSI)
parm:           single_cmd:Use single command to communicate with codecs (for debugging only).
parm:           jackpoll_ms:Ms between polling for jack events (default = 0, using unsol events only)
parm:           probe_only:Only probing and no codec initialization.
parm:           probe_mask:Bitmask to probe codecs (default = -1).
parm:           bdl_pos_adj:BDL position adjustment offset.
parm:           position_fix:DMA pointer read method.(-1 = system default, 0 = auto, 1 = LPIB, 2 = POSBUF, 3 = VIACOMBO, 4 = COMBO, 5 = SKL+, 6 = FIFO).
parm:           model:Use the given board model.
parm:           enable:Enable Intel HD audio interface.
parm:           id:ID string for Intel HD audio interface.
parm:           index:Index value for Intel HD audio interface.
