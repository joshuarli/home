===== identity and environment =====

$ date -u
<date>

$ hostname
home-installer

$ id
uid=0(root) gid=0(root)

$ uname -a
Linux home-installer 6.18.39-0-lts #1-Alpine SMP PREEMPT_DYNAMIC <timestamp> x86_64 Linux

$ uptime
<uptime>

--- /etc/alpine-release ---
3.24.1

--- /etc/hostname ---
home-installer

--- /etc/os-release ---
NAME="Alpine Linux"
ID=alpine
VERSION_ID=3.24.1
PRETTY_NAME="Alpine Linux v3.24"
HOME_URL="https://alpinelinux.org/"
BUG_REPORT_URL="https://gitlab.alpinelinux.org/alpine/aports/-/issues"

--- /etc/profile.d/home-installer.sh ---
unavailable

$ env
RC_VERSION=0.63.2
EINFO_LOG=home-installer-qemu
SHLVL=4
RC_RUNSCRIPT_PID=<pid>
RC_CACHEDIR=/var/cache/rc
RC_CMD=start
RC_SVCNAME=home-installer-qemu
IS_QEMU=1
RC_BOOTLEVEL=boot
TERM=linux
RC_SERVICE=/etc/init.d/home-installer-qemu
RC_UNAME=Linux
SVCNAME=home-installer-qemu
PATH=/usr/libexec/rc/sbin:/usr/libexec/rc/bin:/bin:/sbin:/usr/bin:/usr/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
RC_PID=<pid>
FETCH_FIXTURE=1
RC_LIBEXECDIR=/usr/libexec/rc
INSTALLER_DISK=/dev/vdb
RC_SVCDIR=/run/openrc
RC_OPENRC_PID=<pid>
RC_TMPDIR=/run/openrc/tmp
RC_DEFAULTLEVEL=default
RC_RUNLEVEL=default
PWD=/
QEMU_NET_IFACE=

